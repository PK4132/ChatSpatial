#: ../../concepts.md:118
msgid "Warning signs:"
msgstr "警示信号："

#: ../../concepts.md:119
msgid "One cell type dominates everywhere (>80%)"
msgstr "某一种细胞类型在几乎所有位置占主导（>80%）"

#: ../../concepts.md:120
msgid "Proportions don't match expected tissue composition"
msgstr "比例与预期组织组成不符"

#: ../../concepts.md:121
msgid "Results change dramatically with different methods"
msgstr "不同方法得到的结果差异过大"

#: ../../concepts.md:125
msgid "Interpreting Spatial Statistics"
msgstr "解读空间统计结果"

#: ../../concepts.md:127
msgid "**Moran's I interpretation**:"
msgstr "**Moran's I 解释：**"

#: ../../concepts.md:128
msgid "I > 0: Clustered (similar values near each other)"
msgstr "I > 0：聚集（相似值彼此相邻）"

#: ../../concepts.md:129
msgid "I ~ 0: Random"
msgstr "I ≈ 0：随机"

#: ../../concepts.md:130
msgid "I < 0: Dispersed (dissimilar values near each other)"
msgstr "I < 0：离散（不相似值彼此相邻）"

#: ../../concepts.md:132
msgid "**p-value**: Tests if pattern is significant vs random."
msgstr "**p-value**：检验该模式相对于随机是否显著。"

