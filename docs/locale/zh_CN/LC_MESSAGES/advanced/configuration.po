#: ../../advanced/configuration.md:25 ../../advanced/configuration.md:74
#: ../../advanced/configuration.md:115
msgid "**Key points:**"
msgstr "**要点：**"

#: ../../advanced/configuration.md:26
msgid "The `--` separates the Python path from the module arguments"
msgstr "`--` 用于分隔 Python 路径与模块参数"

#: ../../advanced/configuration.md:27
msgid "Always use absolute path from `which python`"
msgstr "始终使用 `which python` 输出的绝对路径"

#: ../../advanced/configuration.md:28
msgid "Use `--scope user` to make ChatSpatial available across all projects"
msgstr "使用 `--scope user` 让 ChatSpatial 在所有项目中可用"

#: ../../advanced/configuration.md:32
msgid "Codex (CLI and IDE Extension)"
msgstr "Codex（CLI 与 IDE 扩展）"

#: ../../advanced/configuration.md:34
msgid ""
"Codex stores MCP configuration in `~/.codex/config.toml`. The CLI and IDE "
"extension share this configuration."
msgstr ""
"Codex 将 MCP 配置存放在 `~/.codex/config.toml` 中。CLI 与 IDE 扩展共用该配"
"置。"

#: ../../advanced/configuration.md:36
msgid "**Add via CLI:**"
msgstr "**通过 CLI 添加：**"

#: ../../advanced/configuration.md:51
msgid "**Or edit `~/.codex/config.toml` directly:**"
msgstr "**或直接编辑 `~/.codex/config.toml`：**"

#: ../../advanced/configuration.md:63
msgid "**Advanced options:**"
msgstr "**高级选项：**"

#: ../../advanced/configuration.md:75
msgid "Use `[mcp_servers.chatspatial]` (underscore, not hyphen)"
msgstr "使用 `[mcp_servers.chatspatial]`（下划线，不是连字符）"

#: ../../advanced/configuration.md:76
msgid "Configuration is shared between CLI and IDE extension"
msgstr "配置在 CLI 与 IDE 扩展间共享"

#: ../../advanced/configuration.md:77
msgid "Use `/mcp` in Codex TUI to verify connection"
msgstr "在 Codex TUI 中使用 `/mcp` 验证连接"

#: ../../advanced/configuration.md:81
msgid "OpenCode (CLI and TUI)"
msgstr "OpenCode（CLI 与 TUI）"

#: ../../advanced/configuration.md:83
msgid "OpenCode stores MCP configuration in:"
msgstr "OpenCode 将 MCP 配置存放在："

#: ../../advanced/configuration.md:85
msgid "Global: `~/.config/opencode/opencode.json`"
msgstr "全局：`~/.config/opencode/opencode.json`"

#: ../../advanced/configuration.md:86
msgid "Project: `opencode.json` (in your project root)"
msgstr "项目：`opencode.json`（位于项目根目录）"

#: ../../advanced/configuration.md:88
msgid "Project config takes precedence when both exist."
msgstr "当两者同时存在时，以项目配置优先。"

#: ../../advanced/configuration.md:90
msgid "**Add via CLI (wizard):**"
msgstr "**通过 CLI 添加（向导）：**"

#: ../../advanced/configuration.md:97
msgid "**Or edit config JSON directly (recommended for repeatability):**"
msgstr "**或直接编辑配置 JSON（推荐，便于复现）：**"

#: ../../advanced/configuration.md:116
msgid "Use the **absolute** Python path from `which python`"
msgstr "使用 `which python` 输出的 **绝对** Python 路径"

#: ../../advanced/configuration.md:117
msgid "`command` is an array: `[executable, ...args]`"
msgstr "`command` 是一个数组：`[executable, ...args]`"

#: ../../advanced/configuration.md:118
msgid "Prefer project-level `opencode.json` if you want repo-specific settings"
msgstr "如果你希望使用仓库级设置，优先使用项目级 `opencode.json`"

#: ../../advanced/configuration.md:119
msgid "Docs: https://opencode.ai/docs/mcp"
msgstr "文档：https://opencode.ai/docs/mcp"

