# Sphinx build output
_build/
_autosummary/

# Large binary files (keep PNG, exclude PDF)
*.pdf

# Compiled translation catalogs (generated during builds)
locale/**/LC_MESSAGES/*.mo

# Sphinx generated files
.doctrees/
.buildinfo

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temporary files
tmp/
temp/
